# 环境变量配置
# 复制此文件为 .env.local 并填入真实值

# Infer API Key（OpenAI 兼容接口）
INFER_API_KEY=your_infer_api_key_here
OPENAI_API_KEY=${INFER_API_KEY}
OPENAI_BASE_URL=https://api-infer.agentsey.ai/v1
AI_MODEL=gpt-5.3-codex
AI_MODEL_REQUIREMENT=gpt-5.4
AI_MODEL_CODE_REVIEW_A=gpt-5.3-codex
AI_MODEL_CODE_REVIEW_B=claude-sonnet-4-5
AI_MODEL_CODE_REVIEW_STRATEGY=round_robin

# GitHub PR 状态读取
# GITHUB_TOKEN=ghp_xxx
# GitHub Sync（主动拉取主仓 commits 自动标记回灌）
# GITHUB_INTERNAL_REPO_FULL_NAME=org/internal-repo
# GITHUB_INTERNAL_REPO_BRANCH=main
# GITHUB_SYNC_COMMITS_PER_PAGE=30
# GitHub OAuth（外部协作者登录）
# GITHUB_CLIENT_ID=Iv1.xxxxx
# GITHUB_CLIENT_SECRET=xxxxx
# APP_BASE_URL=http://localhost:3000

# Meegle / Lark 回调验签（你可自定义同一个值）
# MEEGLE_WEBHOOK_SECRET=meegle-local-dev-001
# LARK_CALLBACK_SECRET=lark-local-dev-001

# Meegle MCP（主动拉取模式）
# MEEGLE_MCP_URL=https://meegle.com/mcp_server/v1
# MEEGLE_MCP_TOKEN=m-xxxx
# MEEGLE_MCP_VIEW_URL=https://meegle.com/...
# MEEGLE_PROJECT_KEY=your_project_key
# MEEGLE_STATUS_FIELD_KEY=status
# MEEGLE_STATUS_IN_PROGRESS_VALUE=进行中
# MEEGLE_STATUS_RESOLVED_VALUE=已解决

# WLFI 配置
# Demo 模式：true = 模拟支付（不发真实交易），false = 调用真实 WLFI SDK
WLFI_DEMO_MODE=true

# WLFI 网络（base / ethereum / sepolia 等）
WLFI_NETWORK=base

# ERC-20 代币合约地址（留空则使用 native ETH 转账）
# WLFI_TOKEN_ADDRESS=0x...

# WLFI_HOME 路径（安装后自动配置，默认为 ~/.wlfi_agent）
# WLFI_HOME=/Users/yourname/.wlfi_agent
